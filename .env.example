# ======== DATABASE ========
DATABASE_URL=postgresql+asyncpg://golfins_user:golfins_pass@postgres:5432/golfins
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10

# ======== REDIS ========
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=10

# ======== RABBITMQ ========
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ======== JWT / SECURITY ========
SECRET_KEY=your-secret-key-here-change-in-production-use-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ======== S3 / MinIO ========
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=golfins
S3_REGION=us-east-1

# ======== SMTP / EMAIL ========
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASSWORD=test
SMTP_FROM_EMAIL=noreply@golfins.local
SMTP_FROM_NAME=Golfins

# ======== SERVICE URLS ========
AUTH_SERVICE_URL=http://auth-service:8000
POLICY_SERVICE_URL=http://policy-service:8000
PREMIUM_ENGINE_URL=http://premium-engine:8000
CLAIMS_SERVICE_URL=http://claims-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
DOCUMENT_SERVICE_URL=http://document-service:8000

# ======== FRONTEND ========
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_APP_NAME=Golfins

# ======== LOGGING ========
LOG_LEVEL=INFO
LOG_FORMAT=json

# ======== ENVIRONMENT ========
DEBUG=false
ENVIRONMENT=development

# ======== PAGINATION ========
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
